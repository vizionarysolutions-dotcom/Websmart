# Database (Neon PostgreSQL)
# Get this from your Neon dashboard at https://neon.tech
DATABASE_URL=******host/dbname

# Email (Gmail)
# Use an App Password if you have 2FA enabled: https://myaccount.google.com/apppasswords
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-gmail-app-password

# Admin notifications email (defaults to EMAIL_USER if not set)
ADMIN_EMAIL=admin@yourdomain.com

# Server port (defaults to 5000)
PORT=5000

# Node environment
NODE_ENV=production
